# ── Database ────────────────────────────────────────────────────────────────────
# Local:      mysql://avolo_user:password@localhost:3306/avolo
# Production: mysql://avolo_user:<pass>@localhost:3306/avolo  (Plesk MySQL)
DATABASE_URL="mysql://avolo_user:password@localhost:3306/avolo"

# ── NextAuth ────────────────────────────────────────────────────────────────────
# Generate:   openssl rand -base64 32
AUTH_SECRET="generate-with-openssl-rand-base64-32"
# Local dev:  http://localhost:3000
# Production: https://www.avolo.app
AUTH_URL="http://localhost:3000"
SITE_URL="https://www.avolo.app"
NEXTAUTH_URL="http://localhost:3000"

# ── OAuth Providers ─────────────────────────────────────────────────────────────
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ── AI Providers (sequential failover: Groq → Gemini → Nvidia) ──────────────────
GROQ_API_KEY=""
GEMINI_API_KEY=""
NVIDIA_API_KEY=""

# ── Travel APIs ─────────────────────────────────────────────────────────────────
TRAVELPAYOUTS_API_KEY=""
TRAVELPAYOUTS_MARKER=""
DUFFEL_ACCESS_TOKEN=""
AMADEUS_CLIENT_ID=""
AMADEUS_CLIENT_SECRET=""
AMADEUS_ENABLED="false"

# ── Email (Nodemailer / magic link auth) ─────────────────────────────────────────
SMTP_HOST="father.wurk.dk"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@avolo.app"

# ── Google APIs ─────────────────────────────────────────────────────────────────
# Google Maps / Places API — enable "Places API" in Google Cloud Console for this key
GOOGLE_MAPS_API_KEY=""

# ── Unsplash ─────────────────────────────────────────────────────────────────────
UNSPLASH_ACCESS_KEY=""

# ── Currency API ────────────────────────────────────────────────────────────────
# Used for live exchange rate updates (optional — falls back to static rates)
CURRENCY_API_KEY=""

# ── Cron (POST /api/cron) ───────────────────────────────────────────────────────
# Generate:   openssl rand -base64 32
# Set in Plesk cron: curl -X POST https://www.avolo.app/api/cron -H "x-cron-secret: $CRON_SECRET"
CRON_SECRET="generate-with-openssl-rand-base64-32"

# ── Node environment ────────────────────────────────────────────────────────────
NODE_ENV="development"
PORT="3000"
HOSTNAME="0.0.0.0"
